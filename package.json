{
  "name": "@avanio/auth-header",
  "version": "0.0.1",
  "description": "Typescript/Javascript http auth header utils",
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsup src/index.ts --sourcemap --format cjs,esm --dts --clean",
    "prepublishOnly": "npm run build",
    "test": "nyc mocha",
    "coverage": "nyc report --reporter=lcovonly",
    "lint": "eslint src",
    "validate": "tsc --noEmit"
  },
  "files": [
    "dist"
  ],
  "mocha": {
    "exit": true,
    "extension": [
      "ts",
      "js"
    ],
    "recursive": true,
    "require": [
      "ts-node/register",
      "source-map-support/register"
    ],
    "reporters": [
      "spec",
      "mocha-junit-reporter"
    ]
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AvanioOy/auth-header.git"
  },
  "keywords": [
    "http",
    "header",
    "auth",
    "typescript"
  ],
  "author": "mharj",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/AvanioOy/auth-header/issues"
  },
  "homepage": "https://github.com/AvanioOy/auth-header#readme",
  "devDependencies": {
    "@stylistic/eslint-plugin": "^2.4.0",
    "@types/chai": "^4.3.16",
    "@types/mocha": "^10.0.7",
    "@types/node": "^18.19.42",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "chai": "^4.5.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^8.10.0",
    "eslint-config-standard": "^17.1.0",
    "eslint-plugin-deprecation": "^1.5.0",
    "eslint-plugin-prettier": "^4.2.1",
    "eslint-plugin-sonarjs": "^0.19.0",
    "mocha": "^10.7.0",
    "nyc": "^15.1.0",
    "prettier": "^2.8.8",
    "ts-node": "^10.9.2",
    "tsup": "^8.2.3",
    "typescript": "^5.5.4"
  }
}
